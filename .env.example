# PostgreSQL Database Connection URL
# Định dạng: postgresql://[username]:[password]@[host]:[port]/[database_name]
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/Web_orc

# ===== SMTP Configuration (Gmail) =====
# Bước 1: Đăng nhập tài khoản Gmail trên trình duyệt
# Bước 2: Vào https://myaccount.google.com/apppasswords
# Bước 3: Tạo App Password mới (chọn "Mail" và "Other: Vietnam LPR")
# Bước 4: Copy mật khẩu ứng dụng 16 ký tự và paste vào SMTP_PASSWORD bên dưới
#
# Nếu không cấu hình SMTP, hệ thống sẽ chạy ở chế độ Development:
# - OTP sẽ được in ra console (terminal) thay vì gửi email
# - Vẫn có thể test toàn bộ luồng đăng ký/xác thực
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
