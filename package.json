{
  "name": "lpr-yolo-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n \"BACKEND,FRONTEND\" -c \"yellow,cyan\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd anpr-backend && python -m uvicorn src.main:app --host 0.0.0.0 --port 8000 --reload"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
